MinMaxs: F[Nat,Nat,mut MinMax] {min, max -> Block#
  .var _min = {min}
  .var _max = {max}
  .return {mut MinMax: {
  read .min: Nat -> _min.get;
  read .max: Nat -> _max.get;
  mut .min(n: Nat): Void -> _min.set(n);
  mut .max(n: Nat): Void -> _max.set(n);
  }}}

