ListBasicsTests: Test {::
  .check{List[Str] .size .assertEq 0}
  .check{List[Int] .isEmpty .assertEq True}
  .check{List[Int].orderHash{::} == List[Int].assertEq True}
  .check{List[Str] .str{::.str} .assertEq `[]`}
  .check{List[List[Str]] .str{::.str{::.str}} .assertEq `[]`}
  .check{List[Str] .opt 0 .isEmpty .assertEq True}
  .check{List[Str] .first .isEmpty .assertEq True}
  .check{List[Str] .last .isEmpty .assertEq True}
  .check{List[Str] .reverse .size .assertEq 0}
  .check{List[Str] .subList 0 .size .assertEq 0}
  .check{List[Str] ++ (Lists#`a`) .size .assertEq 1}
  .check{List[Str] ++ (Lists#`a`) .get 0 .assertEq `a`}
  .check{List[Int] ++ (Lists# +1) .get 0 .assertEq +1}
  .check{List[Str] <+ `a` .size .assertEq 1}
  .check{List[Str] <+ `a` .get 0 .assertEq `a`}
  .check{List[Str] +> `a` .size .assertEq 1}
  .check{List[Str] +> `a` .get 0 .assertEq `a`}
  .check{List[Str] .withAlso(0, `a`) .size .assertEq 1}
  .check{List[Str] .withAlso(0, `a`) .get 0 .assertEq `a`}
  .check{List[Str] .withAlso(0, `a`) .str{::.str} .assertEq(Lists#`a` .str{::.str})}
  .check{Lists#(+1,+2) ++ (Lists#(+3,+4)) .size .assertEq 4}
  .check{Lists#(+1,+2) ++ (Lists#(+3,+4)) .get 0 .assertEq +1}
  .check{Lists#(+1,+2) ++ (Lists#(+3,+4)) .get 1 .assertEq +2}
  .check{Lists#(+1,+2) ++ (Lists#(+3,+4)) .get 2 .assertEq +3}
  .check{Lists#(+1,+2) ++ (Lists#(+3,+4)) .get 3 .assertEq +4}
  .check{Lists#(+1) ++ (Lists#(+2)) ++ (Lists#(+3)) .size .assertEq 3}
  .check{Lists#(+1) ++ (Lists#(+2)) ++ (Lists#(+3)) .get 2 .assertEq +3}
  .check{Lists#`a` .opt 0 .isEmpty .assertEq False}
  .check{Lists#`a` .opt 1 .isEmpty .assertEq True}
  .check{Lists#(`a`,`b`) .first .isEmpty .assertEq False}
  .check{Lists#(`a`,`b`) .last .isEmpty .assertEq False}
  .check{Lists#(`a`,`b`,`c`) .subList(0,0) .size .assertEq 0}
  .check{Lists#(`a`,`b`,`c`) .subList(0,1) .get 0 .assertEq `a`}
  .check{Lists#(`a`,`b`,`c`) .subList(1,3) .size .assertEq 2}
  .check{Lists#(`a`,`b`,`c`) .subList(1,3) .get 0 .assertEq `b`}
  .check{Lists#(`a`,`b`,`c`) .subList(1,3) .get 1 .assertEq `c`}
  .check{Lists#(`a`,`b`,`c`) .subList 3 .size .assertEq 0}
  .check{Lists#(`a`,`b`,`c`) .reverse .get 0 .assertEq `c`}
  .check{Lists#(`a`,`b`,`c`) .reverse .get 2 .assertEq `a`}
  .check{Lists#(+1,+2,+3) .reverse .get 0 .assertEq +3}
  .check{Lists#(`a`,`b`,`c`).orderHash{::} == (Lists#(`a`,`b`,`c`)).assertEq True}
  .check{Lists#(`a`,`b`,`c`).orderHash{::} == (Lists#(`a`,`b`,`c`).reverse.reverse).assertEq True}
  .check{Lists#(`a`,`b`) .with(0, `x`) .get 0 .assertEq `x`}
  .check{Lists#(`a`,`b`) .with(1, `x`) .get 1 .assertEq `x`}
  .check{Lists#(`a`,`c`) .withAlso(1, `b`) .size .assertEq 3}
  .check{Lists#(`a`,`c`) .withAlso(1, `b`) .get 0 .assertEq `a`}
  .check{Lists#(`a`,`c`) .withAlso(1, `b`) .get 1 .assertEq `b`}
  .check{Lists#(`a`,`c`) .withAlso(1, `b`) .get 2 .assertEq `c`}
  .check{Lists#(`a`,`b`,`c`) .without 0 .get 0 .assertEq `b`}
  .check{Lists#(`a`,`b`,`c`) .without 2 .get 1 .assertEq `b`}
  .check{Lists#(`a`,`b`,`c`) .without 1 .size .assertEq 2}
  .check{Lists#(`a`,`b`,`c`) .without 1 .get 0 .assertEq `a`}
  .check{Lists#(`a`,`b`,`c`) .without 1 .get 1 .assertEq `c`}
  .check{List[List[Str]] .withAlso(0, Lists#`a`) .get 0 .get 0 .assertEq `a`}
  .check{List[List[Int]] .withAlso(0, Lists#(+1,+2)) .get 0 .size .assertEq 2}
  .check{List[List[Int]] .withAlso(0, Lists#(+1,+2)) .get 0 .get 1 .assertEq +2}
  .check{Lists#(Lists#`a`) ++ (Lists#(Lists#`b`)) .size .assertEq 2}
  .check{Lists#(Lists#`a`) ++ (Lists#(Lists#`b`)) .get 0 .get 0 .assertEq `a`}
  .check{Lists#(Lists#`a`) ++ (Lists#(Lists#`b`)) .get 1 .get 0 .assertEq `b`}
  .check{List[List[Str]] .withAlso(0, Lists#`a`) .str{::.str{::.str}} .assertEq( Lists#(Lists#`a`) .str{::.str{::.str}})}
  }

TestList: Test {::
  .test ListBasicsTests
  }
