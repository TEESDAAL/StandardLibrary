Wrapper[S,T]: DataType[S,S] {
  read .get: T -> this.getDataType.close;
  read .name: Str;
  read .getDataType: DataType[T,T];
  .str -> this.name+"["+(this.getDataType.close(this.get).str)+"]";
  read #(t:T): S;
  .hash -> this.getDataType.close(this.get).hash;
  .cmp(a,b,m) ->
    this.getDataType.cmp(this.close(a).get, this.close(b).get, m);
  read .close(s: read S): read Wrapper[S,T];
  .info->this.getDataType.close(this.get).info;
  .imm->this#(this.get);
}
XNat:Wrapper[XNat,Nat]{.name->"X"; .getDataType -> 0;
  # t ->{ .getDataType->t }; .close->this; .close->::; }
YNat:Wrapper[YNat,Nat]{.name->"Y"; .getDataType -> 0;
  # t ->{ .getDataType->t }; .close->this; .close->::; }
WidthNat:Wrapper[WidthNat,Nat]{.name->"Width"; .getDataType -> 0;
  # t ->{ .getDataType->t }; .close->this; .close->::; }
HeightNat:Wrapper[HeightNat,Nat]{.name->"Height"; .getDataType -> 0;
  # t ->{ .getDataType->t }; .close->this; .close->::; }

Red:Wrapper[Red,Byte]{.name->"Red"; .getDataType -> 0.getByte;
  # t ->{ .getDataType->t }; .close->this; .close->::; }
Green:Wrapper[Green,Byte]{.name->"Green"; .getDataType -> 0.getByte;
  # t ->{ .getDataType->t }; .close->this; .close->::; }
Blue:Wrapper[Blue,Byte]{.name->"Blue"; .getDataType -> 0.getByte;
  # t ->{ .getDataType->t }; .close->this; .close->::; }
Alpha:Wrapper[Alpha,Byte]{.name->"Alpha"; .getDataType -> 0.getByte;
  # t ->{ .getDataType->t }; .close->this; .close->::;
  .opaque:Alpha->Alpha#(255.getByte);
  .transparent:Alpha->Alpha#(0.getByte);
  }
Hue:Wrapper[Hue,Float]{.name->"Hue"; .getDataType -> 0.0;
  # t ->Block#(t.assertInRange(0.0=~~=1.0, {"Hue must be between 0 and 1"}),
  { .getDataType->t });
  .close->this; .close->::; }
Saturation:Wrapper[Saturation,Float]{.name->"Saturation"; .getDataType -> 0.0;
  # t ->Block#(t.assertInRange(0.0=~~=1.0,{"Saturation must be between 0 and 1"}),
  { .getDataType->t });
  .close->this; .close->::; }
Brightness:Wrapper[Brightness,Float]{.name->"Brightness"; .getDataType -> 0.0;
  # t ->Block#(t.assertInRange(0.0=~~=1.0,{"Brightness must be between 0 and 1"}),
  { .getDataType->t });
  .close->this; .close->::; }

KeyStroke:Wrapper[KeyStroke,Str]{.name->"KeyStroke"; .getDataType -> "";
  # t ->{ .getDataType->t }; .close->this; .close->::; }

Time:Wrapper[Time,Nat]{.name->"Time"; .getDataType -> 0;
  # t ->{ .getDataType->t };
  .seconds(t:Nat):Time->this#(t*1000000);
  .milliSeconds(t:Nat):Time->this#(t*1000);
  .close->this; .close->::; }
Color:DataType[Color,Color]{
  .close->this; .close->::;
  read .red:Red->{};
  read .green:Green->{};
  read .blue:Blue->{};
  read .alpha:Alpha->Alpha.opaque;
  #(red:Red,green:Green,blue:Blue,alpha:Alpha):Color->{
    .red->red;
    .green->green;
    .blue->blue;
    .alpha->alpha;
    };
  .str -> "Color["+(this.red)+", "+(this.green)+", "+(this.blue)+", "+(this.alpha)+"]";
  .hash ->     this.red.hash
    .hashWith (this.green.hash)
    .hashWith (this.blue.hash)
    .hashWith (this.alpha.hash);
  .cmp(a,b,m) -> a.str<=>(b.str,m);//TODO: improve
  .info->this.str.info;
  .imm->Color#(this.red,this.green,this.blue,this.alpha);
  .transparent:Color->Color#({},{},{},Alpha.transparent);
  .boringGray:Color->
    Color#(Red#(160.getByte),Green#(160.getByte),Blue#(160.getByte),Alpha.opaque);
  .voidBlack:Color->
    Color#(Red#(0.getByte),Green#(0.getByte),Blue#(0.getByte),Alpha.opaque);
  .ghostWhite:Color->
    Color#(Red#(245.getByte),Green#(245.getByte),Blue#(245.getByte),Alpha.opaque);
  .rubberDuck:Color->
    Color#(Red#(255.getByte),Green#(220.getByte),Blue#(40.getByte),Alpha.opaque);
  .bananaBruise:Color->
    Color#(Red#(126.getByte),Green#(96.getByte),Blue#(32.getByte),Alpha.opaque);
  .dangerTomato:Color->
    Color#(Red#(230.getByte),Green#(64.getByte),Blue#(48.getByte),Alpha.opaque);
  .lavaOrange:Color->
    Color#(Red#(255.getByte),Green#(96.getByte),Blue#(16.getByte),Alpha.opaque);
  .wizardPurple:Color->
    Color#(Red#(116.getByte),Green#(64.getByte),Blue#(196.getByte),Alpha.opaque);
  .sleepyBlue:Color->
    Color#(Red#(72.getByte),Green#(120.getByte),Blue#(210.getByte),Alpha.opaque);
  .deepNapBlue:Color->
    Color#(Red#(24.getByte),Green#(48.getByte),Blue#(112.getByte),Alpha.opaque);
  .goblinGreen:Color->
    Color#(Red#(40.getByte),Green#(170.getByte),Blue#(64.getByte),Alpha.opaque);
  .toxicSlime:Color->
    Color#(Red#(120.getByte),Green#(255.getByte),Blue#(32.getByte),Alpha.opaque);
  .alienMint:Color->
    Color#(Red#(128.getByte),Green#(255.getByte),Blue#(190.getByte),Alpha.opaque);
  .swampTea:Color->
    Color#(Red#(82.getByte),Green#(112.getByte),Blue#(54.getByte),Alpha.opaque);
  .rustyRobot:Color->
    Color#(Red#(174.getByte),Green#(86.getByte),Blue#(44.getByte),Alpha.opaque);
  .dustyRose:Color->
    Color#(Red#(196.getByte),Green#(120.getByte),Blue#(132.getByte),Alpha.opaque);
  .blueberrySoup:Color->
    Color#(Red#(64.getByte),Green#(72.getByte),Blue#(176.getByte),Alpha.opaque);
  .terminalGreen:Color->
    Color#(Red#(32.getByte),Green#(220.getByte),Blue#(80.getByte),Alpha.opaque);
  .panicPink:Color->
    Color#(Red#(255.getByte),Green#(72.getByte),Blue#(168.getByte),Alpha.opaque);
  .cardboard:Color->
    Color#(Red#(178.getByte),Green#(136.getByte),Blue#(86.getByte),Alpha.opaque);
  .moonCheese:Color->
    Color#(Red#(236.getByte),Green#(226.getByte),Blue#(148.getByte),Alpha.opaque);
  }
Widget[S]:{
  mut .self:mut S;
  mut .save(mut Consumer[S]):mut S;
  mut .topInset(Nat):mut S;
  mut .topInset'(HeightNat):mut S;
  mut .bottomInset(Nat):mut S;
  mut .bottomInset'(HeightNat):mut S;
  mut .leftInset(Nat):mut S;
  mut .leftInset'(WidthNat):mut S;
  mut .rightInset(Nat):mut S;
  mut .rightInset'(WidthNat):mut S;
  mut .heightGap(Nat):mut S;
  mut .heightGap'(HeightNat):mut S;
  mut .widthGap(Nat):mut S;
  mut .widthGap'(WidthNat):mut S;
  mut .width(Nat):mut S;
  mut .height(Nat):mut S;
  mut .width'(WidthNat):mut S;
  mut .height'(HeightNat):mut S;
  mut .autoWidth:mut S;
  mut .autoHeight:mut S;
  mut .radius(Nat):mut S;
  mut .foreground(Color):mut S;
  mut .background(Color):mut S;
  mut .autoSize:mut S;
  mut .style(s:mut Scope[S]):mut S->Block#(s.run(this.self),this.self);
  read .topInset: HeightNat;
  read .bottomInset: HeightNat;
  read .leftInset:WidthNat;
  read .rightInset:WidthNat;
  read .heightGap:HeightNat;
  read .widthGap:WidthNat;
  read .width:Opt[WidthNat];
  read .height:Opt[HeightNat];
  read .radius:Nat;
  read .foreground:Color;
  read .background:Color;
}
Border:Widget[Border]{
  .self->this;
  mut .mouse(mut Scope[Mouse]):mut Border;
  mut .north(mut Scope[Pane]):mut Border;
  mut .south(mut Scope[Pane]):mut Border;
  mut .east(mut Scope[Pane]):mut Border;
  mut .west(mut Scope[Pane]):mut Border;
  mut .center(mut Scope[Pane]):mut Border;
  mut .northB(mut Scope[Border]):mut Border;
  mut .southB(mut Scope[Border]):mut Border;
  mut .eastB(mut Scope[Border]):mut Border;
  mut .westB(mut Scope[Border]):mut Border;
  mut .centerB(mut Scope[Border]):mut Border;
  mut .paint(Painter):mut Border;
}
Button: Widget[Button]{
  .self-> this;
  mut .action(mut MF[Void]):mut Button;
  mut .text(Str):mut Button;
  mut .textSize(HeightNat):mut Button;
  mut .textHeight(n:Nat): mut Button->this.textSize(HeightNat#n);
  read .text:Str;
  read .textSize:HeightNat;
}

ModelFps: {
  mut .action(mut MF[Void]): mut ModelFps;
}
Frame:{
  mut .title(s: Str): mut Frame;
  read .title: Str;
  mut .fps(fps: Nat): mut Frame;
  read .fps: Nat;
  read .elapsed: Time;  //Time since game time zero (warmup end), as seen by the last repaint tick.
  read .screenSizeW: WidthNat;
  read .screenSizeH: HeightNat;
  read .locationX: XNat;//Note: on some OS the OS may place a window at negative coordinates, reported here as 0.
  read .locationY: YNat;
  mut .modelFps(fps: Nat, s: mut Scope[ModelFps]): mut Frame;
  mut .content(s: mut Scope[Pane]): Void;
  mut .contentB(s: mut Scope[Border]): Void;
  mut .location(XNat, YNat): mut Frame;
  mut .onKey(mut Scope[Keys]): mut Frame;
  mut .maximized: mut Frame;
  //The user may resize by dragging the window edges; without arguments the
  //initial size is computed from the content, with arguments it is as given.
  //Note: an undecorated window can be technically resizable, but there is no
  //border to drag, so the user cannot actually resize it.
  mut .resizable: mut Frame;
  mut .resizable(w: WidthNat, h: HeightNat): mut Frame;
  //The window size cannot be changed by the user; without arguments the size
  //is computed from the content, with arguments it is exactly as given.
  mut .fixedSize: mut Frame;
  mut .fixedSize(w: WidthNat, h: HeightNat): mut Frame;
  mut .undecorated(a: Alpha): mut Frame;
  mut .decorated: mut Frame;
  }
Graphics:{
  mut .color(Color): mut Graphics;
  mut .position(XNat, YNat): mut Graphics;
  mut .line(XNat, YNat): mut Graphics;
  mut .rect(WidthNat, HeightNat): mut Graphics;
  mut .oval(WidthNat, HeightNat): mut Graphics;
  mut .image(Image): mut Graphics;
  read .elapsed: Time;
  read .screenWidth: WidthNat;
  read .screenHeight: HeightNat;
  read .panelWidth: WidthNat;
  read .panelHeight: HeightNat;
  }
Gui:{ mut .run(mut Consumer[mut Frame]): Void }//public interface TopF{ void run(Frame f); }
