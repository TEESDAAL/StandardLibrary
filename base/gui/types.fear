  .mouseY:YNat;
  .elapsed:Time;
  .screenWidth:WidthNat;
  .screenHeight:HeightNat;
  .panelWidth:WidthNat;
  .panelHeight:HeightNat;
}
Pane:Widget[Pane]{
  .self->this;
  mut .mouse(mut Scope[Mouse]):mut Pane;
  mut .pane(mut Scope[Pane]):mut Pane;
  mut .border(mut Scope[Border]):mut Pane;
  mut .button(mut Scope[Button]):mut Pane;
  mut .label(mut Scope[Label]):mut Pane;
  mut .clear:mut Pane;
  mut .paint(Painter):mut Pane;
}
Scope[T]:{ mut .run(mut T): mut T; }
Painter:{ .run(mut Graphics): mut Graphics; }

Consumer[E:*]:{ mut .accept(E):Void; }
Slots: {#[E:*]: mut Slot[E] -> Block#
  .var[mut Opt[E]] e = {{}}
  .return {mut Slot[E:*]:Consumer[E] {'slot
    .accept x-> slot.fill x;
    mut  !: E -> e.get!;
    read !: read/imm E -> e.get!;
    mut .fill(x: E): Void -> e.set(e.get.match{
      .some _ -> Error.msg `Slot was already full`;
      .empty  -> Opts#x;
      });
    read .isFull: Bool -> e.get.isSome;
    mut .opt: mut Opt[E] -> e.get;
    //read .opt: read Opt[read/imm E] -> e.get; //TODO: correctly returning Opt[E], but it is undesirable?
    }};
  }
KeyEvent:{
  .elapsed:Time;
  .screenWidth:WidthNat;
  .screenHeight:HeightNat;
  .windowWidth:WidthNat;
  .windowHeight:HeightNat;
  .keyStroke:KeyStroke;
}
KeyActions:{#:mut KeyAction->Block#
  .let[mut EList[KeyStroke]] match= {ELists#}
  .let[mut EList[mut Consumer[KeyEvent]]] actions= {ELists#}
  .return{mut KeyAction:{'self
    mut .match: mut EList[KeyStroke]->match;
    mut .actions: mut EList[mut Consumer[KeyEvent]]->actions;
    mut .matchOnly( k:KeyStroke): mut KeyAction->
      Block#(match.clear,match.add(k),self);
    mut .matchAlso( k:KeyStroke): mut KeyAction->
      Block#(match.add(k),self);
    mut .doOnly( c:mut Consumer[KeyEvent]): mut KeyAction->
      Block#(actions.clear,actions.add(c),self);
    mut .doAlso( c:mut Consumer[KeyEvent]): mut KeyAction->
      Block#(actions.add(c),self);
    mut .save(c:mut Consumer[mut KeyAction]):mut KeyAction->
      Block#(c.accept(self),self);
    mut .style(c:mut Scope[KeyAction]):mut KeyAction->
      Block#(c.run(self),self);
  }}
}
Keys:{
  mut .pressed(mut Scope[KeyAction]):mut Keys;
  mut .released(mut Scope[KeyAction]):mut Keys;
  }
