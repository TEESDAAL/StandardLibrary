MathTests: F[Tests,Tests] {::
  .testSuite MathConstantsTests
  .testSuite LnTests
  .testSuite LogTests
  .testSuite LogbTests
  .testSuite Log2Tests
  .testSuite AsinTests
  .testSuite AcosTests
  .testSuite AtanTests
  .testSuite Atan2Tests
  .testSuite EuclideanModTests
  .testSuite HypotTests
  .testSuite MaxMinTests
  .testSuite MatchTests
  .testSuite DegreeTests
  .testSuite RadianTests
  }

_FloatTest: {
  .within(actual: Float, expected: Float, delta: Float): Void ->
    actual.assertInRange(expected - delta, expected + delta);

  .closeTo(actual:Float, expected: Float): Void ->
    this.within(
      actual, expected, +0.000100000000000000004792173602385929598312941379845142364501953125
      );
  }

MathConstantsTests: F[Tests,Tests] {::
  .test(Math.minInt.assertEq(-9_223_372_036_854_775_808))
  .test(Math.maxInt.assertEq(+9_223_372_036_854_775_807))
  .test(Math.intBits.assertEq(64))

  .test(Math.minNat.assertEq(0))
  .test(Math.maxNat.assertEq(18_446_744_073_709_551_615))
  .test(Math.natBits.assertEq(64))

  .test(Math.minByte.assertEq(0.byte))
  .test(Math.maxByte.assertEq(255.byte))
  .test(Math.byteBits.assertEq(8))

  .test(Math.floatBits.assertEq(64))
  .test(Math.inf.assertEq(+1.0 / +0.0))
  .test(Math.negInf.assertEq((-1.0) / +0.0))
  .test(Math.nan.isNaN.assertTrue)

  .test(Math.pi.assertInRange(
    +3.141592653589793115997963468544185161590576171875,
    +3.141592653589793115997963468544185161590576171875
  ))

  .test(Math.tau.assertEq(Math.pi * +2.0))

  .test(Math.e.assertInRange(
    +2.718281828459045090795598298427648842334747314453125,
    +2.718281828459045978974017998552881181240081787109375
  ))
  }

LnTests: F[Tests,Tests] {::
  .test(Math.ln(+0.0).assertEq(Math.negInf))
  .test(Math.ln(-0.0).assertEq(Math.negInf))
  .test(Math.ln(Math.inf).assertEq(Math.inf))
  .test(Math.ln(+2.0).assertInRange(
    +0.693147170000000034661979952943511307239532470703125,
    +0.69314718055994528622676398299518041312694549560546875
    ))
  .test(Math.ln(Math.e).assertEq(+1.0))
  .test(Math.ln(+1.0).assertEq(+0.0))
  .testFails{Math.ln(-1.0)}
  .testFails{Math.ln(Math.nan)}
  .testFails{Math.ln(Math.negInf)}
  }

LogTests: F[Tests,Tests] {::
  .test(Math.log(+0.0).assertEq(Math.negInf))
  .test(Math.log(-0.0).assertEq(Math.negInf))
  .test(Math.log(Math.inf).assertEq(Math.inf))

  .test(Math.log(+10.0).assertEq(+1.0))
  .test(Math.log(+1.0).assertEq(+0.0))
  .test(Math.log(+2.0).assertInRange(
    +0.301029995599999988797890182468108832836151123046875,
    +0.301029995800000005345964382286183536052703857421875
  ))

  .testFails{Math.log(-1.0)}
  .testFails{Math.log(Math.nan)}
  .testFails{Math.log(Math.negInf)}
  }


LogbTests: F[Tests,Tests] {::
  .test(Math.logb(+2.0, +8.0).assertEq(+3.0))
  .test(Math.logb(+10.0, +100.0).assertEq(+2.0))
  .test(_FloatTest.closeTo(Math.logb(+3.0, 3**5.float), +5.0))

  .test(Math.logb(+2.0, +1.0).assertEq(+0.0))
  .test(Math.logb(+2.0, +0.0).assertEq(Math.negInf))
  .test(Math.logb(+2.0, Math.inf).assertEq(Math.inf))

  .testFails{Math.logb(+2.0, -1.0)}
  .testFails{Math.logb(-2.0, +4.0)}
  .testFails{Math.logb(+0.0, +4.0)}
  .testFails{Math.logb(Math.nan, +1.0)}
  .testFails{Math.logb(+3.0, Math.nan)}
  }


Log2Tests: F[Tests,Tests] {::
  .test(Math.log2(+8.0).assertEq(+3.0))
  .test(Math.log2(+1.0).assertEq(+0.0))
  .test(Math.log2(+7.0).assertInRange(
    +2.8073549209999999476394805242307484149932861328125,
    +2.8073549230000001131202225224114954471588134765625
  ))
  .test(Math.log2(+0.0).assertEq(Math.negInf))
  .test(Math.log2(Math.inf).assertEq(Math.inf))

  .testFails{Math.log2(-1.0)}
  .testFails{Math.log2(Math.nan)}
  }


AsinTests: F[Tests,Tests] {::
  .test(Math.asin(+0.0)#.assertEq(+0.0))
  .test(Math.asin(-0.0)#.assertEq(-0.0))

  .test(Math.asin(+1.0)#.assertEq(Math.pi / +2.0))
  .test(Math.asin(-1.0)#.assertEq(Math.pi / -2.0))

  .testFails{Math.asin(+2.0)}
  .testFails{Math.asin(-2.0)}
  .testFails{Math.asin(Math.nan)}
  }


AcosTests: F[Tests,Tests] {::
  .test(Math.acos(+1.0)#.assertEq(+0.0))
  .test(Math.acos(-1.0)#.assertEq(Math.pi))
  .test(Math.acos(+0.0)#.assertEq(Math.pi / +2.0))

  .testFails{Math.acos(+2.0)}
  .testFails{Math.acos(-2.0)}
  .testFails{Math.acos(Math.nan)}
  }


AtanTests: F[Tests,Tests] {::
  .test(Math.atan(+0.0)#.assertEq(+0.0))
  .test(Math.atan(-0.0)#.assertEq(-0.0))

  .test(Math.atan(+1.0)#.assertEq(Math.pi / +4.0))
  .test(Math.atan(-1.0)#.assertEq(Math.pi / -4.0))

  .test(Math.atan(Math.inf)#.assertEq(Math.pi / +2.0))
  .test(Math.atan(Math.negInf)#.assertEq(Math.pi / -2.0))

  .testFails{Math.atan(Math.nan)}
  }


Atan2Tests: F[Tests,Tests] {::
  .test(Math.atan2(+1.0, +0.0)#.assertEq(Math.pi / +2.0))
  .test(Math.atan2(-1.0, +0.0)#.assertEq(Math.pi / -2.0))

  .test(Math.atan2(+0.0, +1.0)#.assertEq(+0.0))
  .test(Math.atan2(+0.0, -1.0)#.assertEq(Math.pi))

  .testFails{Math.atan2(Math.nan, +1.0)}
  .testFails{Math.atan2(+1.0, Math.nan)}
  }


EuclideanModTests: F[Tests,Tests] {::
  .test(Math.euclideanMod(+3.0, +7.0).assertEq(+3.0))
  .test(Math.euclideanMod(-3.0, +7.0).assertEq(+4.0))

  .test(Math.euclideanMod(+10.0, +5.0).assertEq(+0.0))
  .test(Math.euclideanMod(-10.0, +5.0).assertEq(+0.0))

  .test(Math.euclideanMod(+3.0, -7.0).assertEq(+3.0))
  }



HypotTests: F[Tests,Tests] {::
  .test(Math.hypot(+3.0, +4.0).assertEq(+5.0))
  .test(Math.hypot(+0.0, +0.0).assertEq(+0.0))

  .test(Math.hypot(Math.inf, +1.0).assertEq(Math.inf))
  .test(Math.hypot(+1.0, Math.inf).assertEq(Math.inf))

  .testFails{Math.hypot(Math.nan, +1.0)}
  .testFails{Math.hypot(+1.0, Math.nan)}
  }

_Persons: F[Str, Nat, _Person]{
  name, age -> {.name -> name; .age -> age;}
  }

_Person: {
  read .name: Str;
  read .age: Nat;
  }

MaxMinTests: F[Tests,Tests] {::
  .test(Math.max(1, 2, {::}).assertEq(2))
  .test(Math.min(2, 1, {::}).assertEq(1))
  .test(
    Math.max(_Persons#(`Alice`, 32), _Persons#(`Bob`, 8), {::.age})
      .name.assertEq(`Alice`)
    )
  .test(
    Math.min(_Persons#(`Alice`, 32), _Persons#(`Bob`, 8), {::.age})
      .name.assertEq(`Bob`)
    )
  .test(
    Math.min(_Persons#(`Carol`, 32), _Persons#(`Daniel`, 32), {::.age})
      .name.assertEq(`Carol`)
    )
  .test(
    Math.max(_Persons#(`Carol`, 32), _Persons#(`Daniel`, 32), {::.age})
      .name.assertEq(`Carol`)
    )
  }


MatchTests: F[Tests,Tests] {::
  .test(Math.match(+5.0, this.matcher).assertEq(1))
  .test(Math.match(+0.0, this.matcher).assertEq(2))
  .test(Math.match(-0.0, this.matcher).assertEq(3))
  .test(Math.match(Math.inf, this.matcher).assertEq(4))
  .test(Math.match(Math.negInf, this.matcher).assertEq(5))
  .test(Math.match(Math.nan, this.matcher).assertEq(6));

  read .matcher: iso FloatMatch[Nat] -> {
    .regular x -> 1;
    .posZero -> 2;
    .negZero -> 3;
    .posInf -> 4;
    .negInf -> 5;
    .nan -> 6;
    };
  }

DegreeTests: F[Tests,Tests] {::
  .test(Degrees#(+180.0)!.toRad#.assertEq(Math.pi))
  .test(Degrees#(+360.0)!.normalize#.assertEq(+0.0))
  .test(Degrees#(-90.0)!.normalize#.assertEq(+270.0))

  .test(Degrees#(+0.0)!.sin.assertEq(+0.0))
  .test(Degrees#(+90.0)!.sin.assertEq(+1.0))
  .test(_FloatTest.closeTo(Degrees#(+180.0)!.sin, +0.0))
  .test(Degrees#(+270.0)!.sin.assertEq(-1.0))

  .test(Degrees#(+0.0)!.cos.assertEq(+1.0))
  .test(_FloatTest.closeTo(Degrees#(+90.0)!.cos, +0.0))
  .test(Degrees#(+180.0)!.cos.assertEq(-1.0))
  .test(_FloatTest.closeTo(Degrees#(+270.0)!.cos, +0.0))

  .test(
    Degrees#(Math.nan).isEmpty
      & (Degrees#(Math.inf).isEmpty)
      & (Degrees#(Math.negInf).isEmpty)
      .assertTrue
    )
  }


RadianTests: F[Tests,Tests] {::
  .test(Radians#(Math.pi)!.toDeg.assertEq(Degrees#(+180.0)!))
  .test(Radians#(Math.tau)!.normalize#.assertEq(+0.0))
  .test(Radians#(Math.tau / -4.0)!.normalize#.assertEq(Math.tau * +3.0 / +4.0))

  .test(_FloatTest.closeTo(Radians#(+0.0)!.cos, +1.0))
  .test(_FloatTest.closeTo(Radians#(Math.pi / +2.0)!.cos, +0.0))
  .test(_FloatTest.closeTo(Radians#(Math.pi)!.cos, -1.0))
  .test(_FloatTest.closeTo(Radians#(Math.tau * +3.0 / +4.00)!.cos, +0.0))

  .test(_FloatTest.closeTo(Radians#(+0.0)!.tan, +0.0))
  .test(_FloatTest.closeTo(Radians#(Math.pi / +4.0)!.tan, +1.0))
  .test(_FloatTest.closeTo(Radians#(Math.pi)!.tan, +0.0))
  .test(_FloatTest.closeTo(Radians#(Math.pi * +3.0 / +4.0)!.tan, -1.0))

  // tan(x) -> +-inf as x -> pi/2
  .test(Radians#(Math.pi / +2.0)!.tan >= (+10.0 ** +10.0) .assertTrue)
  .test(Radians#(Math.pi / +2.0 + (+10.0 ** -6.0))!.tan <= (+10.0 ** +10.0) .assertTrue)
  .test(
    Radians#(Math.nan).isEmpty
      & (Radians#(Math.inf).isEmpty)
      & (Radians#(Math.negInf).isEmpty)
      .assertTrue
    )
  }