Tests: {
  .test(v: Void): Tests -> this;
  .testFails[R:*](f: F[R]): Tests -> Block#
    .do{Try#(f).assertInfo}
    .return{this};
  .done: Void -> {};
  .testSuite(f: F[Tests,Tests]): Tests -> f#this;
  }

AllTest: Main { s->
  Tests
    .testSuite FloatArith
    .testSuite FloatRound
    .testSuite FloatPred
    .testSuite FloatIeee
    .testSuite FloatConv
    .testSuite FloatRange
    .testSuite FloatLiteralFormsLarge
    .testSuite FloatSignNum

    .testSuite NumArith
    .testSuite NumRound
    .testSuite NumFloorCeilTrunc
    .testSuite NumIsInteger
    .testSuite NumConv
    .testSuite NumRange
    .testSuite NumRationalLiteralForms
    .testSuite NumRationalTokenizationWitness
    .testSuite NumSign

    .testSuite IntArith
    .testSuite IntDivRem
    .testSuite IntWrapIndex
    .testSuite IntConv
    .testSuite IntAlu
    .testSuite IntRangeChecks
    .testSuite IntLiteralForms
    .testSuite IntBoundaryAndBoundedVsAlu
    .testSuite IntRange
    .testSuite IntSign

    .testSuite NatArith
    .testSuite NatDivRem
    .testSuite NatIndexOffset
    .testSuite NatConv
    .testSuite NatAlu
    .testSuite NatRangeChecks
    .testSuite NatLiteralForms
    .testSuite NatBoundaryAndBoundedVsAlu
    .testSuite NatRange

    .testSuite ByteArith
    .testSuite ByteDivRem
    .testSuite ByteConv
    .testSuite ByteAlu
    .testSuite ByteRangeChecks
    .testSuite ByteBoundaryAndBoundedVsAlu
    .testSuite ByteRange
    
    .testSuite StrBasics
    .testSuite StrConcat
    .testSuite StrSepOps
    .testSuite StrTokenSeparation
    .testSuite StrOrder
    .testSuite StrEscape
    .testSuite StrParseInt
    .testSuite StrParseNat
    .testSuite StrParseByte
    .testSuite StrParseNum
    .testSuite StrParseFloat
    .testSuite StrParseIeeeFloat

    .testSuite ListBasics
    .testSuite MapBasics
    
    .testSuite TestFlowsBasics
    .testSuite TestListsBasics
    .testSuite TestListOps
    .testSuite TestOrderBasics
    .testSuite TestOrderByAndFlows
    .testSuite TestMapsAndSets
    .testSuite TestOrderingCollections
    .testSuite TestRepr
    
    .testSuite UStrTest

    .testSuite MathTests
    .done
  }

TestLog: Main { _ -> Log.log(`Hello`) }