StackFrame: DataType[StackFrame,StackFrame] {
  .fileName: Str; .typeName: Str; .methodName: Str; .lineNumber: Nat;
  .close -> this; .close -> ::;
  .cmp a, b, m -> a.str<=>(b.str,m);
  .hash -> this.str.hash;
  .str -> 
    `StackFrame[` + (this.imm.fileName)
    + `, ` + (this.imm.typeName)
    + `, ` + (this.imm.methodName)
    + `, ` + (this.imm.lineNumber)
    +`]`;
  .info -> Infos.map(
    `fileName`, this.imm.fileName,
    `typeName`, this.imm.typeName,
    `methodName`, this.imm.methodName,
    `lineNumber`, this.imm.lineNumber,
    );
  }

StackFrames: F[Str,Str,Str,Nat,StackFrame] { fn,tn,mn,ln ->
  {'self .fileName->fn; .typeName->tn; .methodName->mn; .lineNumber->ln; .imm->self} }

/// Unit tests
///This design blends test suites, tests and individual checks.
///Basically, a test suite is a Test that only calls `.test` on named Tests,
///While a Test is a named Test that only calls `.check`.
///We can then arbitrary make trees of test suites or by nesting them in other test suites.
///
///A name name is only reported when the name is present.
///Example code with two test suites.
///```
///MyTests: UnitTests {::
///  .test TestCars
///  .test TestPerson
///  }
///TestCars: Test {::
///  .let x=... //can declare locals
///  //Test `TestCarsCanMove` inside test suite TestCars
///  .test TestCarsCanMove: Test {:: .check {..}}
///  
///  //disabled test with name inside test suite TestCars
///  .disableTest TestCarsCanFly: Test {:: .check {..}}
///  
///  //unnamed check in the test suite.. possible but not advised
///  .check {Cars#(...).assertEquals(MakeCar#23)  }
///  
///  //A single test can have many checks
///  .test TestCarsCanPark: Test {t-> Block#
///    .if {..} .do{ t.check {..} }
///    .if {..} .do{ t.check {..} }
///    .done}
///  }
/// ```
/// Example using logs:
/// ```
/// Events:InMemoryLog[Event]{"Events"}
///...
/// .checkWithSys { sys -> Block#
///   .let log=Events.reader(sys);
///   .do { log.clear }
///   .do { actionUnderTest# }
///   .do { log.consume.assertEq({::},Lists#(
///     Event1#(...),
///     Event2#(...),
///     ))}
///   .done
///   }
/// ```
UnitTests: Main {
  .main sys->Block#
    .let[mut RTestCap] ts= {_TestCaps#(sys,ELists#)}
    .do {Block#(this.tests(ts),Void)}
    .return {ts.run};
  .tests(t: mut TestCap): mut TestCap;
  }

TestCap: Sealed {//by making it sealed we can guaranteed the output of the function is the same of the original input
  //so we can use subtyping to get more methods on that object/rely on the injected EList
  mut .let[T](f: F[T],c: TestCont[T]): mut TestCap -> c#(f#,this);
  //so .let must be just imm stuff, nothing else makes sense.
  mut .test(t: Test): mut TestCap -> t.tests this;
  mut .disabledTest(Test): mut TestCap;
  mut .check(Check): mut TestCap;
  mut .disabledCheck(Check): mut TestCap; 
  mut .checkWithSys(CheckSys): mut TestCap;
  mut .disabledCheckWithSys(CheckSys): mut TestCap;  
  }

TestCont[T]: { #(t: T, self: mut TestCap): mut TestCap }

_TestCaps: {
  #(sys: mut System, ts: mut EList[CheckInfo]): mut RTestCap -> mut RTestCap: TestCap {'self
    .check c -> Block#
      .let[List[StackFrame]] st = {c._fetchTrace {sys.try.currentStackTrace}}
      .do {UnitTestLog.log(_PlanLine#(`RUN`,st,2))}
      .do {ts.add(CheckInfos#(
        { _ -> c#; ._fetchTrace f -> c._fetchTrace f },
        st))}
      .return {self};

    .checkWithSys c -> Block#
      .let[List[StackFrame]] st = {c._fetchTrace {sys.try.currentStackTrace}}
      .do {UnitTestLog.log(_PlanLine#(`RUN`,st,2))}
      .do {ts.add(CheckInfos#(c,st))}
      .return {self};

    .disabledCheck c -> Block#(
      UnitTestLog.log(_PlanLine#(`DISABLED`,c._fetchTrace {sys.try.currentStackTrace},1)),
      self);

    .disabledCheckWithSys c -> Block#(
      UnitTestLog.log(_PlanLine#(`DISABLED`,c._fetchTrace {sys.try.currentStackTrace},1)),
      self);

    .disabledTest _ -> Block#(
      UnitTestLog.log(_PlanLine#(`DISABLED`,sys.try.currentStackTrace,1)),
      self);

    mut .run: Void ->
      ts.seqFlow.forEach { ci->
        UnitTestLog.log(_AddToLog#(ci.stackTrace,sys.try#(sys.iso.close,{ t -> ci.check#t }),2))
      }
    }
  }

Check: { #: Void; ._fetchTrace(f: mut MF[List[StackFrame]]): List[StackFrame]->f#; }
CheckSys: { #(sys: mut System): Void; ._fetchTrace(f: mut MF[List[StackFrame]]): List[StackFrame]->f#; }

CheckInfos: F[CheckSys,List[StackFrame],CheckInfo] {c,st->CheckInfo: {
  .check: CheckSys->c; .stackTrace: List[StackFrame]->st;}}

Test: { .tests(t: mut TestCap): mut TestCap; }

_AddToLog: {
  #(st: List[StackFrame], a: mut Action[Void], dept: Nat): Str ->
    a.run {
      .ok _ ->
        `<testcase classname="` + (_XmlEscape#(st.get(dept).typeName))
        + `" name="` + (_XmlEscape#(st.get(dept).typeName)) + ` at line: ` + (st.get(dept).lineNumber)
        + `" file="` + (_XmlEscape#(st.get(dept).fileName))
        + `" line="` + (st.get(dept).lineNumber)
        + `"></testcase>` |;
      .info i ->Block#(
        Debug#(`Test failure`
          + (st.get(dept).typeName) + ` at line: ` 
          + (st.get(dept).lineNumber) + ` in file: `+ (st.get(dept).fileName)
          ),
        `<testcase classname="` + (_XmlEscape#(st.get(dept).typeName))
        + `" name="` + (_XmlEscape#(st.get(dept).typeName)) + ` at line: ` + (st.get(dept).lineNumber)
        + `" file="` + (_XmlEscape#(st.get(dept).fileName))
        + `" line="` + (st.get(dept).lineNumber)
        + `">`
        | (_FormatFailure#i)
        | `</testcase>` |
        );
    };
  }

_FailureMsg: {
  #(i: Info): Str ->
    i.msg.isEmpty ? {
      .then -> i.map.opt(`msg`).match {
        .some e -> e.msg;
        .empty -> i.str;
      };
      .else -> i.msg;
    };
  }

_FailureExpected: {
  #(i: Info): Str ->
    i.map.opt(`expected`).match {
      .some e -> Block#(
        Debug#(`Expected: `+(e.msg)),
        `<expected>` + (_XmlEscape#(e.msg)) + `</expected>`
        );
      .empty -> ``;
    };
  }

_FailureActual: {
  #(i: Info): Str ->
    i.map.opt(`actual`).match {
      .some e -> Block#(
        Debug#(`Actual: `+(e.msg)),
        `<actual>` + (_XmlEscape#(e.msg)) + `</actual>`);
      .empty -> ``;
    };
  }

_FailureList: {
  #(i: Info): Str ->
    i.map.opt(`list`).match {
      .some e -> `` | (e.list.flow.map {_FailureTrace#::}.join (`` |));
      .empty -> ``;
    };
  }

_FormatFailure: {
  #(i: Info): Str ->
    `<failure>`
    | (_FailureExpected#i)
    | (_FailureActual#i)
    | (_XmlEscape#(_FailureMsg#i))
    + (_XmlEscape#(_FailureList#i))
    | `</failure>`;
  }

_FrameField: { #(i: Info, k: Str): Str ->
  i.map.opt(k).orLazy{Error.msg(`Malformed stack frame info, missing key: ` + k)}.msg
  }

_FailureTrace: { #(i: Info): Str -> Block#
  .let[Str] fn = {_FrameField#(i, `fileName`)}
  .let[Str] tn = {_FrameField#(i, `typeName`)}
  .let[Str] mn = {_FrameField#(i, `methodName`)}
  .let[Str] ln = {_FrameField#(i, `lineNumber`)}
  .let[Nat] sp = {mn.indexOf(` `).orLazy{Error.msg(`Malformed stack frame methodName: ` + mn)}}
  .return {
    mn.sub(0,sp + 1)
    + tn
    + (mn.sub(sp + 1,mn.size))
    + ` error line: ` + ln
    + ` in file ` + fn
    }
  }

_PlanLine: {
  #(kind: Str, st: List[StackFrame], dept: Nat): Str ->
    `PLAN|`
    + kind
    + `|`
    + (st.get(dept).fileName)
    + `|`
    + (st.get(dept).typeName)
    + `|`
    + (st.get(dept).typeName) + ` at line: ` + (st.get(dept).lineNumber)
    + `|`
    + (st.get(dept).lineNumber)|;//| to end in new line
  }

_XmlEscape: {
  #(s: Str): Str ->
    s.replaceSimultaneous(Lists#(
      `&`, `&amp;`,
      `<`, `&lt;`,
      `"`, `&quot;`,
      ));}