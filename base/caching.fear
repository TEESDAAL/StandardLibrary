CaptureFree: {}//special type rule will make sure zero captures
Norm[T]:Sealed{ .get: T; }//this means only base can make norms, so we control production of Norms
CacheF[R]: CaptureFree{//Any instantiated type implementing CacheF will be a singleton (becase of NonCaputure)
  #: R;
  ._get: R -> Magic!//this.myCache.get()
  //via magic it defines
  //Cache0<Object> myCache= new Cache0<>(new AtomicReference<Entry<Object>>(),1,this);
  }
CacheF[A,R]: CaptureFree{//Any instantiated type implementing CacheF will be a singleton (becase of NonCaputure)
  #(Norm[A]): R;
  ._get(a: Norm[A]): R -> Magic!//this.myCache.get(a)
  //via magic it defines
  //Cache1<Object,Object> myCache= new Cache1<>(new ConcurrentHashMap<Norm<Object>,Entry<Object>>(),1,this);
  }
CacheF[A,B,R]: CaptureFree{//Any instantiated type implementing CacheF will be a singleton (becase of NonCaputure)
  #(Norm[A], Norm[B]): R;
  ._get(a: Norm[A], b: Norm[B]): R -> Magic!//this.myCache.get(a,b)
  //via magic it defines
  //Cache2<Object,Object,Object> myCache= new Cache2<>(new ConcurrentHashMap<Cache2.Key<Object,Object>,Entry<Object>>(),1,this);
  }
CacheMemo[R]: CaptureFree{//Any instantiated type implementing CacheF will be a singleton (becase of NonCaputure)
  #: R;
  ._get: Norm[R] -> Magic!//this.myCache.get(a)
  //via magic it defines
  //Cache0<Object> myCache= new Cache0<>(new AtomicReference<Entry<Object>>(),1,()->new Norm<R>(this.imm$$hash$0()));
  }
CacheMemo[A,R]: CaptureFree{//Any instantiated type implementing CacheF will be a singleton (becase of NonCaputure)
  #(Norm[A]): R;
  ._get(a: Norm[A]): Norm[R] -> Magic!//this.myCache.get(a)
  //via magic it defines
  //Cache1<Object,Object> myCache= new Cache1<>(new ConcurrentHashMap<Norm<Object>,Entry<Object>>(),1,(p1)->new Norm<R>(this.imm$$hash$0(p1));
  }
CacheMemo[A,B,R]: CaptureFree{//Any instantiated type implementing CacheF will be a singleton (becase of NonCaputure)
  #(Norm[A], Norm[B]): R;
  ._get(a: Norm[A], b: Norm[B]): Norm[R] -> Magic!//this.myCache.get(a,b)
  //via magic it defines
  //Cache2<Object,Object,Object> myCache= new Cache2<>(new ConcurrentHashMap<Cache2.Key<Object,Object>,Entry<Object>>(),1,(p1,p2)->new Norm<R>(this.imm$$hash$0(p1,p2));  
  }
Cache: {
  #[R](f: CacheF[R]): R -> f._get;
  #[A,R](a: Norm[A], f: CacheF[A,R]): R -> f._get(a);
  #[A,B,R](a: Norm[A], b: Norm[B], f: CacheF[A,B,R]): R -> f._get(a,b);
  .norm[R](f: CacheMemo[R]): Norm[R] -> f._get;
  .norm[A,R](a: Norm[A], f: CacheMemo[A,R]): Norm[R] -> f._get(a);
  .norm[A,B,R](a:Norm[A], b: Norm[B], f: CacheMemo[A,B,R]): Norm[R] -> f._get(a,b);
  }

CacheReprF[A,R]: CaptureFree{
  #(read A): R;
  ._get(read Repr[A]): R -> Magic!//CacheReprF$2.myCache.computeIfAbsent(p0,v->new Cache1(1,v)).get(this);
  //via magic it defines in CacheReprF$2
  //static java.util.concurrent.ConcurrentHashMap<Repr$1, Cache1> myCache= new java.util.concurrent.ConcurrentHashMap<>();
  }
CacheReprF[A,B,R]: CaptureFree{
  #(read A, Norm[B]): R;
  ._get(read Repr[A], Norm[B]): R -> Magic!//CacheReprF$3.myCache.computeIfAbsent(p0,v->new Cache2(1,v)).get(this,p2);
  //via magic it defines in CacheReprF$2
  //static java.util.concurrent.ConcurrentHashMap<Repr$1, Cache2> myCache= new java.util.concurrent.ConcurrentHashMap<>();
  }

_ListNorm:{#[T:*,R](List[T],mut MF[T,Norm[R]]): Norm[List[Norm[R]]]->Magic!}

_ReprCacheFlush:{#[T](mut Repr[T]):Void->Magic!}
//Move the specific thing from message to core to avoid warnings
