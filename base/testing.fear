StackFrame:DataType[StackFrame,StackFrame]{
  .fileName: Str; .typeName: Str; .methodName: Str; .lineNumber: Nat;
  .close -> this; .close -> ::;
  .cmp a, b, m -> a.str<=>(b.str,m);
  .hash -> this.str.hash;
  .str -> 
    `StackFrame[` + (this.imm.fileName)
    + `, ` + (this.imm.typeName)
    + `, ` + (this.imm.methodName)
    + `, ` + (this.imm.lineNumber)
    +`]`;
  .info -> Infos.map(
    `fileName`, this.imm.fileName,
    `typeName`, this.imm.typeName,
    `methodName`, this.imm.methodName,
    `lineNumber`, this.imm.lineNumber,
    );
  }
StackFrames:F[Str,Str,Str,Nat,StackFrame]{ fn,tn,mn,ln -> 
  {'self .fileName->fn; .typeName->tn; .methodName->mn; .lineNumber->ln; .imm->self} }

UnitTests: Main{
  .main sys->Block#
    .let[mut RTestCap] ts={_TestCaps#(sys.try,ELists#)}
    .do {Block#(this.tests(ts),Void)}
    .return {ts.run};
  .tests(t: mut TestCap): mut TestCap;
  }
TestCap: Sealed{//by making it sealed we can guaranteed the output of the function is the same of the original input
  //so we can use subtyping to get more methods on that object/rely on the injected EList
  mut .let[T](f:F[T],c:TestCont[T]): mut TestCap -> c#(f#,this);
  //so .let must be just imm stuff, nothing else makes sense.
  mut .test(t: Test): mut TestCap -> t.tests this;
  mut .disabledTest(Test): mut TestCap;
  mut .check(Check): mut TestCap;
  mut .disabledCheck(Check): mut TestCap;
  }
TestCont[T]: { #(t: T, self: mut TestCap): mut TestCap }
_TestCaps: {
  #(try: mut CapTry, ts: mut EList[CheckInfo]): mut RTestCap -> mut RTestCap:TestCap{'self
    .check c -> Block#
      .let[List[StackFrame]] st = {c._fetchTrace{ try.currentStackTrace }}
      .do {UnitTestLog.log(_PlanLine#(`RUN`,st,2))}
      .do {ts.add(CheckInfos#(c,st))}
      .return {self};
    .disabledCheck c -> Block#(
      UnitTestLog.log(_PlanLine#(`DISABLED`,c._fetchTrace{ try.currentStackTrace },1)),
      self);
    .disabledTest _ -> Block#(
      UnitTestLog.log(_PlanLine#(`DISABLED`,try.currentStackTrace,1)),
      self);
    mut .run: Void ->
      ts.flow.forEach{ ci->UnitTestLog.log(_AddToLog#(ci.stackTrace,try#{ci.check#},2)) }
    }
  }
Check:{ #:Void; ._fetchTrace(f: mut MF[List[StackFrame]]): List[StackFrame]->f#;}
CheckInfos:F[Check,List[StackFrame],CheckInfo]{c,st->CheckInfo:{
  .check:Check->c; .stackTrace:List[StackFrame]->st;}}
Test: { .tests(t: mut TestCap): mut TestCap; }

_AddToLog:{
  #(st: List[StackFrame], a: mut Action[Void], dept: Nat): Str ->
    a.run{
      .ok _ ->
        `<testcase classname="` + (_XmlEscape#(st.get(dept).typeName))
        + `" name="` + (_XmlEscape#(st.get(dept).typeName)) + ` at line: ` + (st.get(dept).lineNumber)
        + `" file="` + (_XmlEscape#(st.get(dept).fileName))
        + `" line="` + (st.get(dept).lineNumber)
        + `"></testcase>` |;
      .info i ->
        `<testcase classname="` + (_XmlEscape#(st.get(dept).typeName))
        + `" name="` + (_XmlEscape#(st.get(dept).typeName)) + ` at line: ` + (st.get(dept).lineNumber)
        + `" file="` + (_XmlEscape#(st.get(dept).fileName))
        + `" line="` + (st.get(dept).lineNumber)
        + `">`
        | (_FormatFailure#i)
        | `</testcase>` |;
    };
  }
_FailureMsg:{
  #(i: Info): Str ->
    i.msg.isEmpty ? {
      .then -> i.map.opt(`msg`).match{
        .some e -> e.msg;
        .empty -> i.str;
      };
      .else -> i.msg;
    };
  }
_FailureExpected:{
  #(i: Info): Str ->
    i.map.opt(`expected`).match{
      .some e -> `<expected>` + (_XmlEscape#(e.msg)) + `</expected>`;
      .empty -> ``;
    };
  }
_FailureActual:{
  #(i: Info): Str ->
    i.map.opt(`actual`).match{
      .some e -> `<actual>` + (_XmlEscape#(e.msg)) + `</actual>`;
      .empty -> ``;
    };
  }
_FailureList:{
  #(i: Info): Str ->
    i.map.opt(`list`).match{
      .some e -> `` | (e.list.flow.map{_FailureTrace#::}.join (`` |));
      .empty -> ``;
    };
  }
_FormatFailure:{
  #(i: Info): Str ->
    `<failure>`
    | (_FailureExpected#i)
    | (_FailureActual#i)
    | (_XmlEscape#(_FailureMsg#i))
    + (_XmlEscape#(_FailureList#i))
    | `</failure>`;
  }
_FrameField:{ #(i: Info, k: Str): Str -> 
  (i.map.opt(k) || {Error.msg(`Malformed stack frame info, missing key: ` + k)}).msg
  }

_FailureTrace:{ #(i: Info): Str -> Block#
  .let[Str] fn = {_FrameField#(i, `fileName`)}
  .let[Str] tn = {_FrameField#(i, `typeName`)}
  .let[Str] mn = {_FrameField#(i, `methodName`)}
  .let[Str] ln = {_FrameField#(i, `lineNumber`)}
  .let[Nat] sp = {mn.indexOf(` `)||{Error.msg(`Malformed stack frame methodName: ` + mn)}}
  .return {
    mn.sub(0,sp + 1)
    + tn
    + (mn.sub(sp + 1,mn.size))
    + ` error line: ` + ln
    + ` in file ` + fn
    }
  }
_PlanLine:{
  #(kind: Str, st: List[StackFrame], dept: Nat): Str ->
    `PLAN|`
    + kind
    + `|`
    + (st.get(dept).fileName)
    + `|`
    + (st.get(dept).typeName)
    + `|`
    + (st.get(dept).typeName) + ` at line: ` + (st.get(dept).lineNumber)
    + `|`
    + (st.get(dept).lineNumber)|;//| to end in new line
  }
_XmlEscape:{
  #(s: Str): Str ->
    s.replaceSimultaneous(Lists#(
      `&`, `&amp;`,
      `<`, `&lt;`,
      `"`, `&quot;`,
      ));}
